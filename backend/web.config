<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="iisnode" path="src/app.js" verb="*" modules="iisnode"/>
    </handlers>

    <rewrite>
      <rules>
        <rule name="NodeInspector" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^src/app.js\/debug[\/]?" />
        </rule>
        <rule name="StaticContent">
          <action type="Rewrite" url="public{REQUEST_URI}"/>
        </rule>
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="True"/>
          </conditions>
          <action type="Rewrite" url="src/app.js"/>
        </rule>
      </rules>
    </rewrite>

    <!-- Security headers applied at the IIS layer.
         These complement the headers set by Helmet in Node.js and ensure
         they are present even if the Node process fails to set them. -->
    <httpProtocol>
      <customHeaders>
        <!-- HSTS: force HTTPS for 1 year, include subdomains -->
        <add name="Strict-Transport-Security"  value="max-age=31536000; includeSubDomains; preload" />
        <!-- Prevent MIME-type sniffing -->
        <add name="X-Content-Type-Options"     value="nosniff" />
        <!-- Deny framing to prevent clickjacking -->
        <add name="X-Frame-Options"            value="DENY" />
        <!-- Limit referrer information sent to third parties -->
        <add name="Referrer-Policy"            value="strict-origin-when-cross-origin" />
        <!-- Disable browser features not needed by this app -->
        <add name="Permissions-Policy"         value="camera=(), microphone=(), geolocation=(), payment=()" />
        <!-- Remove the IIS server version banner -->
        <remove name="X-Powered-By" />
        <remove name="Server" />
      </customHeaders>
    </httpProtocol>

    <security>
      <requestFiltering>
        <hiddenSegments>
          <remove segment="bin"/>
        </hiddenSegments>
        <!-- Reject requests with double-encoded characters -->
        <requestLimits maxAllowedContentLength="10485760" /> <!-- 10 MB -->
      </requestFiltering>
    </security>

    <!-- Pass error responses through to Node.js error handler -->
    <httpErrors existingResponse="PassThrough" />

    <iisnode
      watchedFiles="web.config;*.js"
      loggingEnabled="true"
      logDirectory="iisnode"
      nodeProcessCommandLine="node"
    />
  </system.webServer>
</configuration>
