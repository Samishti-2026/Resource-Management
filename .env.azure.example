# ─────────────────────────────────────────────────────────────────────────────
# Azure Deployment Environment Variables
# Copy this to .env.azure and fill in your values
# NEVER commit .env.azure to git
# ─────────────────────────────────────────────────────────────────────────────

# Azure Container Registry name (without .azurecr.io)
ACR_NAME=your-acr-name

# Docker image tag
IMAGE_TAG=latest

# ── Backend App Settings (set these in Azure Web App → Configuration) ─────────
DATABASE_URL="postgresql://postgres:Pass123%23@resource-utility-db.postgres.database.azure.com:5432/postgres?schema=public&sslmode=require"
JWT_SECRET=resource-management-secret-jwt
JWT_REFRESH_SECRET=resource-management-secret-refresh
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Frontend URL (used for CORS on backend)
CORS_ORIGIN=https://resource-utility-frontend.azurewebsites.net

# ── Frontend App Settings (set these in Azure Web App → Configuration) ────────
# Full URL of the backend Azure Web App (with trailing slash)
BACKEND_URL=https://resource-utility-backend.azurewebsites.net/
