{
  "routes": [
    {
      "route": "/api/*",
      "rewrite": "https://resource-utility-bpaxa2d3g8cpg5cg.centralindia-01.azurewebsites.net/api/*"
    },
    {
      "route": "/health",
      "rewrite": "https://resource-utility-bpaxa2d3g8cpg5cg.centralindia-01.azurewebsites.net/health"
    },
    {
      "route": "/*",
      "serve": "/index.html",
      "statusCode": 200
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/*.{css,js,png,jpg,svg,ico}"]
  },
  "globalHeaders": {
    "Cache-Control": "no-cache"
  }
}
